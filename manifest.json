{
  "manifest_version": 3,
  "name": "Turnstile Auto Solver",
  "version": "3.0.0",
  "description": "Auto-solve Cloudflare Turnstile challenges",
  "permissions": ["webRequest", "scripting"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
