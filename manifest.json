{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "CloudFreed CloudFlare Turnstile Solver",
  "version": "2.0.1",
  "author": "Akmal Abar",
  "description": "Solve CloudFlare Turnstile Challenges Automatically.",
  "action": {
    "default_icon": {
      "128": "CloudFreed.png",
      "16": "CloudFreed.png",
      "48": "CloudFreed.png"
    }
  },
  "icons": {
    "128": "CloudFreed.png",
    "16": "CloudFreed.png",
    "48": "CloudFreed.png"
  },
  "content_scripts": [
    {
      "matches": ["*://challenges.cloudflare.com/*"],
      "run_at": "document_start",
      "all_frames": true,
      "js": ["script.js"]
    },
    {
      "matches": ["*://challenges.cloudflare.com/*"],
      "run_at": "document_start",
      "all_frames": true,
      "js": ["background.js"],
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["background.js"],
      "matches": ["https://challenges.cloudflare.com/*"]
    }
  ]
}
