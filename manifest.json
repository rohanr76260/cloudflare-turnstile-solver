{
  "manifest_version": 3,
  "name": "Turnstile Auto Solver",
  "version": "9.0.0",
  "description": "Auto-solve Cloudflare Turnstile challenges",
  "permissions": ["scripting", "webRequest"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["main-injector.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://*/*"],
      "js": ["solver.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
