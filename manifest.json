{
  "manifest_version": 3,
  "name": "Cloudflare Turnstile Solver",
  "version": "2.0.0",
  "description": "Automatically solve Cloudflare Turnstile challenges",
  "permissions": ["scripting"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["solver.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
